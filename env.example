# Groq API Key
# Get from: https://console.groq.com/keys (free, instant)
GROQ_API_KEY=your_groq_api_key_here

# Turso Database
# Get from: https://turso.tech → create a db → copy URL + token
TURSO_DATABASE_URL=libsql://your-db-name-yourname.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Your WhatsApp number (with country code, no + or spaces)
# Example: 919876543210  (91 = India, rest = your number)
OWNER_PHONE=91XXXXXXXXXX
